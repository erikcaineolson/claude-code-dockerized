# =============================================================================
# Claude Code — Dockerized with PAL MCP Server
# Copy this file to .env and fill in your keys
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Anthropic API Key (for Claude Code itself)
# Get yours at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# PAL MCP Server — AI Provider Keys (at least one required for PAL MCP)
# PAL lets Claude delegate tasks to other AI models. Pick one or more:
# -----------------------------------------------------------------------------

# Google Gemini (free tier available)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (access to many models via one key)
# Get yours at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# xAI / Grok
# Get yours at: https://console.x.ai/
# XAI_API_KEY=

# -----------------------------------------------------------------------------
# PAL MCP Server — Configuration (optional)
# -----------------------------------------------------------------------------

# Model selection: auto, pro, flash, o3, gpt-5.2, etc.
# DEFAULT_MODEL=auto

# Comma-separated list of tools to disable
# Default disabled: NONE
# DISABLED_TOOLS=

# -----------------------------------------------------------------------------
# GitHub CLI (optional — for gh commands inside the container)
# Generate a token at: https://github.com/settings/tokens
# Recommended scopes: repo, read:org, workflow
# -----------------------------------------------------------------------------
# GH_TOKEN=

# -----------------------------------------------------------------------------
# Git Configuration (optional)
# -----------------------------------------------------------------------------
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
